    "Add Your First Provider": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge deinen ersten Anbieter hinzu"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加你的第一个提供商"
          }
        }
      }
    },
    "Add a model to get started": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein Modell hinzu, um loszulegen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加一个模型即可开始"
          }
        }
      }
    },
    "Add a remote MCP server to discover and use its tools": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge einen Remote-MCP-Server hinzu, um seine Tools zu entdecken und zu nutzen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加远程 MCP 服务器以发现并使用其中的工具"
          }
        }
      }
    },
    "Adjust how sensitive voice detection is": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Empfindlichkeit der Spracherkennung anpassen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整语音检测的灵敏度"
          }
        }
      }
    },
    "Affects pause detection, wake word detection, and voice activity thresholds": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beeinflusst Pausenerkennung, Aktivierungswort-Erkennung und Sprachaktivitätsschwellen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "影响停顿检测、唤醒词检测和语音活动阈值"
          }
        }
      }
    },
    "Agent can create its own tools as plugins": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agent kann eigene Tools als Plugins erstellen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体可以将自己的工具创建为插件"
          }
        }
      }
    },
    "Agents": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agenten"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体"
          }
        }
      }
    },
    "Agents execute commands safely": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agenten führen Befehle sicher aus"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体安全执行命令"
          }
        }
      }
    },
    "Agents run shell commands safely": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agenten führen Shell-Befehle sicher aus"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体安全运行 shell 命令"
          }
        }
      }
    },
    "Agents, memory, tools, and identity that live on your Mac.\nModels are interchangeable — everything else compounds, stays with you.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agenten, Gedächtnis, Tools und Identität – direkt auf deinem Mac.\nModelle sind austauschbar – alles andere wächst mit dir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体、记忆、工具和身份都保存在你的 Mac 上。\n模型可以随时替换，其他能力会持续积累并始终归你所有。"
          }
        }
      }
    },
    "Agents, voice, and themes": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agenten, Stimme und Themes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智能体、语音和主题"
          }
        }
      }
    },
    "All": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全部"
          }
        }
      }
    },
    "All Models": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Modelle"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全部模型"
          }
        }
      }
    },
    "All processing happens on your Mac": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Verarbeitung findet auf deinem Mac statt"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有处理都在你的 Mac 上完成"
          }
        }
      }
    },
    "Allow": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlauben"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许"
          }
        }
      }
    },
    "Allow agent to run arbitrary commands in the sandbox": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Agent darf beliebige Befehle in der Sandbox ausführen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许智能体在沙盒中运行任意命令"
          }
        }
      }
    },
    "Allows capturing system audio for transcription. Screen content is not recorded.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt das Aufnehmen von System-Audio für Transkription. Bildschirminhalte werden nicht aufgezeichnet."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许捕获系统音频用于转写。不会录制屏幕内容。"
          }
        }
      }
    },
    "Allows plugins to access and search contacts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf Kontakte zuzugreifen und sie zu durchsuchen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件访问并搜索联系人。"
          }
        }
      }
    },
    "Allows plugins to access protected files like the Messages database and other app data.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf geschützte Dateien wie die Nachrichten-Datenbank und andere App-Daten zuzugreifen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件访问受保护文件，例如信息数据库和其他应用数据。"
          }
        }
      }
    },
    "Allows plugins to access your calendar to read and create events directly.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, direkt auf deinen Kalender zuzugreifen, um Termine zu lesen und zu erstellen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件访问你的日历，以直接读取和创建日程。"
          }
        }
      }
    },
    "Allows plugins to access your current location.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf deinen aktuellen Standort zuzugreifen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件访问你的当前位置。"
          }
        }
      }
    },
    "Allows plugins to access your reminders to read and create tasks.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, auf deine Erinnerungen zuzugreifen, um Aufgaben zu lesen und zu erstellen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件访问提醒事项，以读取和创建任务。"
          }
        }
      }
    },
    "Allows plugins to control Maps app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, die Karten-App via AppleScript zu steuern."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件通过 AppleScript 控制地图应用。"
          }
        }
      }
    },
    "Allows plugins to control other applications using AppleScript and Apple Events.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, andere Apps via AppleScript und Apple Events zu steuern."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件使用 AppleScript 和 Apple Events 控制其他应用。"
          }
        }
      }
    },
    "Allows plugins to interact with UI elements, simulate input, and control the computer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, mit UI-Elementen zu interagieren, Eingaben zu simulieren und den Computer zu steuern."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件与界面元素交互、模拟输入并控制电脑。"
          }
        }
      }
    },
    "Allows plugins to read and create events in Calendar.app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, Termine in Kalender.app via AppleScript zu lesen und zu erstellen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件通过 AppleScript 在日历应用中读取和创建日程。"
          }
        }
      }
    },
    "Allows plugins to read and create notes in the Notes app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, Notizen in der Notizen-App via AppleScript zu lesen und zu erstellen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许插件通过 AppleScript 在备忘录应用中读取和创建笔记。"
          }
        }
      }
    },
    "Allows plugins to read and send emails in Mail.app via AppleScript.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaubt Plugins, Mails in Mail.app via AppleScript zu lesen und zu senden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
